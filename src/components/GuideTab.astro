---
import { Compass, MapPin, ShieldCheck, Milestone } from 'lucide-astro';
import { siteConfig } from '../site.config';

const { guide } = siteConfig;
---

<section id="tab-guide" class="tab-content space-y-6">
  <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl shadow-xl">
    <h2 class="text-2xl font-bold text-accent mb-4 flex items-center gap-2 font-scroll">
      <Compass /> {guide.heading}
    </h2>
    <p class="text-slate-300 leading-relaxed mb-4 text-sm sm:text-base" set:html={guide.intro} />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
      <div class="bg-slate-800 p-4 rounded-xl border border-slate-700">
        <h3 class="font-bold text-emerald-400 mb-2 flex items-center gap-2"><MapPin class="w-4 h-4" /> {guide.keyPointsTitle}</h3>
        <ul class="space-y-2 text-sm text-slate-300">
          {guide.keyPoints.map((item) => <li set:html={item} />)}
        </ul>
      </div>

      <div class="bg-slate-800 p-4 rounded-xl border border-slate-700">
        <h3 class="font-bold text-amber-400 mb-2 flex items-center gap-2"><ShieldCheck class="w-4 h-4" /> {guide.prepTitle}</h3>
        <ul class="space-y-2 text-sm text-slate-300">
          {guide.prep.map((item) => <li set:html={item} />)}
        </ul>
      </div>
    </div>
  </div>

  <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl shadow-xl">
    <h3 class="text-xl font-bold text-accent mb-4 flex items-center gap-2 font-scroll">
      <Milestone /> {guide.routeTitle}
    </h3>
    <div class="space-y-4">
      {guide.route.map((r) => (
        <div class="flex items-start gap-4 p-3 bg-slate-800/50 rounded-xl border border-slate-800">
          <div class={`${r.bg} rounded-full p-2.5 text-center shrink-0`}>
            <span class="font-game text-xs">{r.emoji}</span>
          </div>
          <div>
            <h4 class="font-bold text-slate-100">{r.title}</h4>
            <p class="text-xs sm:text-sm text-slate-400" set:html={r.desc} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
