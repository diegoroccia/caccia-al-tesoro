---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import GuideTab from '../components/GuideTab.astro';
import MapViewer from '../components/MapViewer.astro';
import PlayTab from '../components/PlayTab.astro';
import PrintTab from '../components/PrintTab.astro';
import { Sword, Volume2, BookOpen, Smartphone, Map, Printer, Github } from 'lucide-astro';
import { siteConfig } from '../site.config';

// Stazioni ordinate per campo `order`. Fonte di verità del contenuto della caccia.
const entries = (await getCollection('stations')).sort((a, b) => a.data.order - b.data.order);
const stations = entries.map((e) => ({
  emoji: e.data.emoji,
  title: e.data.title,
  subtitle: e.data.subtitle,
  riddle: e.data.riddle,
  action: e.data.action,
  spoiler: e.data.spoiler,
  sound: e.data.sound,
}));

const tabs = [
  { id: 'guide', label: siteConfig.tabs.guide, Icon: BookOpen },
  { id: 'play', label: siteConfig.tabs.play, Icon: Smartphone },
  { id: 'map', label: siteConfig.tabs.map, Icon: Map },
  { id: 'print', label: siteConfig.tabs.print, Icon: Printer },
];
---

<Layout>
  <header class="bg-slate-900 border-b-4 border-accent p-4 shadow-lg no-print">
    <div class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-3">
        <div class="bg-accent p-2 rounded-lg text-slate-950 animate-bounce">
          <Sword class="w-8 h-8" />
        </div>
        <div>
          <h1 class="text-xl sm:text-2xl font-bold text-accent font-scroll tracking-wider">{siteConfig.brand.name}</h1>
          <p class="text-xs text-slate-400 font-game">{siteConfig.brand.tagline}</p>
        </div>
      </div>
      <button id="test-audio-btn" class="flex items-center gap-2 bg-slate-800 hover:bg-slate-700 px-3 py-1.5 rounded-full border border-slate-600 text-sm transition">
        <Volume2 class="w-4 h-4 text-emerald-400 animate-pulse" />
        <span>{siteConfig.ui.testAudio}</span>
      </button>
    </div>
  </header>

  <nav class="max-w-4xl w-full mx-auto p-4 flex gap-2 no-print">
    {tabs.map(({ id, label, Icon }) => (
      <button
        data-tab={id}
        id={`btn-${id}`}
        class:list={[
          'tab-btn flex-1 py-3 px-2 text-center rounded-xl font-bold border-b-4 transition duration-200',
          id === 'guide' ? 'bg-accent text-slate-950 border-accent-strong' : 'bg-slate-800 text-slate-400 border-slate-950',
        ]}
      >
        <span class="flex items-center justify-center gap-1 text-sm sm:text-base"><Icon class="w-4 h-4" /> {label}</span>
      </button>
    ))}
  </nav>

  <main class="max-w-4xl w-full mx-auto px-4 flex-1">
    <GuideTab />
    <MapViewer />
    <PlayTab stations={stations} />
    <PrintTab entries={entries} />
  </main>

  <footer class="mt-auto border-t border-slate-900 pt-8 text-center text-xs text-slate-500 no-print space-y-2">
    <p>{siteConfig.footer}</p>
    <p>
      <a href={siteConfig.repoUrl} target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-1.5 text-slate-400 hover:text-accent transition">
        <Github class="w-4 h-4" /> Quellcode auf GitHub
      </a>
    </p>
  </footer>
</Layout>

<script>
  import { testAudio } from '../scripts/audio';

  const ACTIVE = ['bg-accent', 'text-slate-950', 'border-accent-strong'];
  const INACTIVE = ['bg-slate-800', 'text-slate-400', 'border-slate-950'];

  function switchTab(tabId: string) {
    document.querySelectorAll<HTMLElement>('.tab-content').forEach((tab) => tab.classList.add('hidden'));
    document.getElementById(`tab-${tabId}`)?.classList.remove('hidden');

    document.querySelectorAll<HTMLElement>('.tab-btn').forEach((btn) => {
      btn.classList.remove(...ACTIVE);
      btn.classList.add(...INACTIVE);
    });
    const activeBtn = document.getElementById(`btn-${tabId}`);
    activeBtn?.classList.remove(...INACTIVE);
    activeBtn?.classList.add(...ACTIVE);

    // Notifica i componenti (es. la mappa deve dimensionarsi solo da visibile).
    document.dispatchEvent(new CustomEvent('tabshown', { detail: tabId }));
  }

  document.querySelectorAll<HTMLElement>('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => switchTab(btn.dataset.tab!));
  });

  document.getElementById('test-audio-btn')?.addEventListener('click', testAudio);
</script>
